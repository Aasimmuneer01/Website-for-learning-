rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Publicly readable content, authenticated users can write for now
    match /resources/{resource} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /categories/{category} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /classes/{classLevel} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /boards/{board} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /announcements/{announcement} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // User profile management
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAuthenticated());
      allow write: if request.auth != null && (request.auth.uid == userId || isAuthenticated());
    }
  }
}
